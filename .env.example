# Database
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# JWT (32+ byte high-entropy secret)
JWT_ISSUER=secure-chat-api
JWT_AUDIENCE=secure-chat-mobile
JWT_SECRET=
JWT_EXPIRES_SECONDS=900

# Google Play Integrity
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account"}
GOOGLE_PLAY_PACKAGE_NAME=com.company.securechat
INTEGRITY_NONCE_TTL_SECONDS=300
INTEGRITY_ATTEST_TTL_SECONDS=600

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=chat-media
R2_PUBLIC_BASE_URL=https://media.example.com
R2_PRESIGN_TTL_SECONDS=300

# Security
ALLOWED_MEDIA_MIME=image/jpeg,image/png,video/mp4,application/pdf
MAX_UPLOAD_BYTES=10485760
